# ----------------------------------------------------------------------------
# xlugar.com environment variables
# All PUBLIC_* vars are inlined at build time (available to SSG + client).
# Copy to .env for local dev; set the same keys in Netlify before deploy.
# ----------------------------------------------------------------------------

# Public base URL of the site (canonical, OG, sitemap, JSON-LD). No trailing slash.
PUBLIC_SITE_URL=https://xlugar.com

# Site identity (SEO defaults + JSON-LD).
PUBLIC_SITE_NAME=xLugar
# Locale drives <html lang> and og:locale. Use en_US for Tier-1 targeting.
PUBLIC_SITE_LOCALE=en_US
PUBLIC_TWITTER_HANDLE=@xlugar

# Chaturbate affiliate campaign / web master tag (Revshare 20%).
# Used by buildAffiliateLink() and the catalog API proxy. NEVER hardcode this.
PUBLIC_CHATURBATE_CAMPAIGN=R1cGT

# --- Catalog tuning (see docs/chaturbate-api.md) ---
# Default geo region for the whole live grid. One of:
# northamerica | southamerica | europe_russia | asia | africa | other.
# `southamerica` is Colombia-heavy — our primary audience. Blank = global.
PUBLIC_DEFAULT_REGION=southamerica
# ISO alpha-2 country code ranked FIRST in the grid (rankRooms). e.g. CO = Colombia.
PUBLIC_PRIORITY_COUNTRY=CO
# How many rooms to pull from CB per request (pool for tag/country filtering).
# Verified safe well above 90; larger = better coverage but heavier payload.
PUBLIC_ROOMS_LIMIT=300

# OPTIONAL — Chaturbate affiliate STATS/earnings API (dashboard only, NOT the
# landing). Requires a token from your affiliate portal. Secret: no PUBLIC_ prefix.
# Leave commented until an earnings dashboard is actually built.
# CHATURBATE_STATS_TOKEN=

# White Label retention destination. Full base URL provisioned in your
# Chaturbate affiliate account (Affiliate > White Labels).
# Affiliate + UTM params are appended automatically. Leave blank to fall back
# to the affiliate home tour for the primary CTA.
PUBLIC_WHITELABEL_URL=

# --- Stripchat / Stripcash (api/models — Links & Creatives) ---
# See docs/stripchat-api.md. The grid mixes Stripchat models with Chaturbate.
# Master switch. 1 = include Stripchat in the hybrid grid; 0/blank = off.
# Keep OFF until PUBLIC_STRIPCHAT_USER_ID below is filled in.
PUBLIC_STRIPCHAT_ENABLED=0
# Your Stripcash affiliate userId (from your default link). Required. NEVER hardcode.
PUBLIC_STRIPCHAT_USER_ID=
# API base host as shown in your Stripcash panel (logged in). No trailing slash.
PUBLIC_STRIPCHAT_API_BASE=https://go.whitetrafsa.com
# White label for Stripchat outbound clicks (retention + commission).
# Blank = fall back to the API clickUrl (already carries your affiliation).
PUBLIC_STRIPCHAT_WHITELABEL_URL=https://cams.xlugar.com
# Optional: share of Stripchat cards in the mix (0..1, e.g. 0.4 = 40%).
# Blank = no quota (pure ranking merge by tier + viewers).
PUBLIC_STRIPCHAT_MIX_RATIO=

# Hero visual (all optional). Point these at a LICENSED asset only — a Chaturbate
# affiliate promo image, an AI-generated render, or licensed stock. Drop the file
# in /public (e.g. public/hero/model.webp) and set the path here. If all blank, a
# compliant SVG silhouette placeholder is shown. Do NOT use a real cam model photo
# without rights (copyright / likeness / 2257).
PUBLIC_HERO_IMAGE=
# Looping video (3D render) alternative — takes priority over the image when set.
PUBLIC_HERO_VIDEO_WEBM=
PUBLIC_HERO_VIDEO_MP4=
# Poster frame for the video (falls back to PUBLIC_HERO_IMAGE).
PUBLIC_HERO_POSTER=

# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX). Optional; no-op if blank.
PUBLIC_GA_MEASUREMENT_ID=

# Google Tag Manager container ID (e.g. GTM-XXXXXXX). Optional; no-op if blank.
PUBLIC_GTM_ID=
