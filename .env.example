# Public base URL of the site (used for canonical, OG, sitemap, JSON-LD).
PUBLIC_SITE_URL=https://xlugar.com

# Site identity (used in SEO defaults and JSON-LD WebSite/Organization).
PUBLIC_SITE_NAME=xLugar
PUBLIC_SITE_LOCALE=es_ES
PUBLIC_TWITTER_HANDLE=@xlugar

# Data layer — swap from mock to real API later without touching components.
# When PUBLIC_API_BASE_URL is set, src/data/getModels.ts can target the live API.
PUBLIC_API_BASE_URL=
# Server-only secrets (never prefixed PUBLIC_) go here, e.g.:
# API_TOKEN=
