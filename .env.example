# ----------------------------------------------------------------------------
# xlugar.com environment variables
# All PUBLIC_* vars are inlined at build time (available to SSG + client).
# Copy to .env for local dev; set the same keys in Netlify before deploy.
# ----------------------------------------------------------------------------

# Public base URL of the site (canonical, OG, sitemap, JSON-LD). No trailing slash.
PUBLIC_SITE_URL=https://xlugar.com

# Site identity (SEO defaults + JSON-LD).
PUBLIC_SITE_NAME=xLugar
# Locale drives <html lang> and og:locale. Use en_US for Tier-1 targeting.
PUBLIC_SITE_LOCALE=en_US
PUBLIC_TWITTER_HANDLE=@xlugar

# Chaturbate affiliate campaign / web master tag (Revshare 20%).
# Used by buildAffiliateLink() and the catalog API proxy. NEVER hardcode this.
PUBLIC_CHATURBATE_CAMPAIGN=R1cGT

# White Label retention destination. Full base URL provisioned in your
# Chaturbate affiliate account (Affiliate > White Labels).
# Affiliate + UTM params are appended automatically. Leave blank to fall back
# to the affiliate home tour for the primary CTA.
PUBLIC_WHITELABEL_URL=

# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX). Optional; no-op if blank.
PUBLIC_GA_MEASUREMENT_ID=

# Google Tag Manager container ID (e.g. GTM-XXXXXXX). Optional; no-op if blank.
PUBLIC_GTM_ID=
