---
/**
 * Solid badge/chip. NO glassmorphism — no backdrop-blur, no semi-transparent
 * fills anywhere. Variants use brand tokens with real contrast.
 */
interface Props {
  variant?: 'primary' | 'premium' | 'accent' | 'success' | 'outline' | 'neutral';
  size?: 'sm' | 'md';
  class?: string;
}
const { variant = 'primary', size = 'md', class: className = '' } = Astro.props;

const base =
  'inline-flex items-center gap-1.5 font-semibold uppercase leading-none rounded-[--radius-pill] whitespace-nowrap';
const sizes = {
  sm: 'text-[0.625rem] px-2.5 py-1 tracking-[0.08em]',
  md: 'text-[0.6875rem] px-3 py-1.5 tracking-[0.08em]',
};
const variants = {
  // solid primary (hot pink) — default/action · TRENDING
  primary: 'bg-primary-500 text-on-primary',
  // solid champagne gold — premium / VIP
  premium: 'bg-premium-500 text-on-premium',
  // solid electric violet — NUEVO
  accent: 'bg-accent-500 text-on-primary',
  // solid border + green text — ONLINE (no transparency tricks)
  success: 'bg-surface text-success border border-success',
  // solid border, solid bg surface (NOT transparent) — VERIFICADO
  outline: 'bg-surface text-fg border border-border-strong',
  neutral: 'bg-surface-2 text-fg-muted',
};
---
<span class:list={[base, sizes[size], variants[variant], className]}>
  <slot />
</span>
