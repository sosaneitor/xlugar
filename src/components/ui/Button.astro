---
/**
 * Button / link with tactile microinteractions (glow + scale on hover/active).
 * Animates transform/opacity + box-shadow only on discrete states (not loops).
 */
interface Props {
  href?: string;
  variant?: 'gradient' | 'primary' | 'premium' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  type?: 'button' | 'submit';
  class?: string;
  rel?: string;
  target?: string;
  'aria-label'?: string;
}
const {
  href,
  variant = 'primary',
  size = 'md',
  type = 'button',
  class: className = '',
  ...rest
} = Astro.props;

const base =
  'group relative inline-flex items-center justify-center gap-2 font-semibold rounded-(--radius-pill) ' +
  'transition-[transform,box-shadow,background-color] duration-(--dur-fast) ease-(--ease-out-soft) ' +
  'hover:-translate-y-0.5 active:translate-y-0 active:scale-[0.98] motion-reduce:transform-none ' +
  'focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-premium-400';
const sizes = {
  sm: 'text-sm px-5 py-2',
  md: 'text-[0.95rem] px-6 py-2.5',
  lg: 'text-base px-8 py-3.5',
};
const variants = {
  // Hero CTA — brand gradient (pink -> violet) with primary glow
  gradient:
    'text-on-primary [background-image:var(--gradient-brand)] hover:shadow-[var(--shadow-glow-primary)]',
  primary: 'bg-primary-500 text-on-primary hover:bg-primary-600 hover:shadow-[var(--shadow-glow-primary)]',
  premium: 'bg-premium-500 text-on-premium hover:bg-premium-400 hover:shadow-[var(--shadow-glow-premium)]',
  ghost: 'bg-surface text-fg border border-border-strong hover:border-premium-500 hover:text-premium-300',
};
const cls = [base, sizes[size], variants[variant], className];
const Tag = href ? 'a' : 'button';
---
<Tag class:list={cls} href={href} type={href ? undefined : type} {...rest}>
  <slot />
</Tag>
