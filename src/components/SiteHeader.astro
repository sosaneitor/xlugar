---
import { SITE } from '@lib/site';
const links = [
  { href: '/#descubre', label: 'Descubre' },
  { href: '/#feed', label: 'Feed' },
  { href: '/#album', label: 'Álbum' },
  { href: '/#catalogo', label: 'Catálogo' },
];
---
<header class="sticky top-0 z-50 border-b border-border bg-bg/100">
  <nav class="mx-auto flex h-16 max-w-6xl items-center justify-between px-5 sm:px-8" aria-label="Principal">
    <a href="/" class="font-display text-xl tracking-tight text-fg" transition:name="brand">
      x<span class="text-primary-500">Lugar</span>
    </a>
    <ul class="hidden items-center gap-7 text-sm text-fg-muted md:flex">
      {links.map((l) => (
        <li>
          <a href={l.href} class="transition-colors duration-(--dur-fast) hover:text-premium-300">{l.label}</a>
        </li>
      ))}
    </ul>
    <a
      href="/#descubre"
      class="rounded-(--radius-md) bg-primary-500 px-4 py-2 text-sm font-medium text-on-primary
             transition-[transform,background-color] duration-(--dur-fast) hover:-translate-y-0.5
             hover:bg-primary-600 motion-reduce:transform-none"
    >
      Entrar
    </a>
  </nav>
</header>
