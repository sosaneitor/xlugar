---
/**
 * CookieConsent — GDPR/ePrivacy consent banner that gates analytics.
 *
 * Why: Google Analytics + Google Tag Manager are non-essential (analytics)
 * cookies. Under GDPR/ePrivacy they must NOT load until the visitor consents.
 * This component is the ONLY place that injects GA/GTM — the loaders fire
 * exclusively after consent is granted (or was granted on a previous visit).
 *
 * Choices are stored in localStorage under `xlugar_cookie_consent`:
 *   'granted' → analytics injected · 'denied' → nothing loads.
 * When no choice is stored the banner is shown. The strictly-necessary age-gate
 * cookie is unaffected and needs no consent.
 *
 * IDs are passed from BaseLayout; when neither is set the banner never renders.
 */
interface Props {
  gaId?: string;
  gtmId?: string;
}
const { gaId = '', gtmId = '' } = Astro.props;
const enabled = Boolean(gaId || gtmId);
---
{enabled && (
  <div id="cookie-consent" hidden>
    <div class="cc__inner">
      <p class="cc__text">
        We use cookies to measure aggregate traffic. Necessary cookies (like your age
        confirmation) are always on. You can accept or reject analytics — see our
        <a href="/cookies">Cookie Policy</a>.
      </p>
      <div class="cc__actions">
        <button type="button" id="cc-reject" class="cc__btn cc__btn--ghost">Reject</button>
        <button type="button" id="cc-accept" class="cc__btn cc__btn--yes">Accept</button>
      </div>
    </div>
  </div>

  <style>
    #cookie-consent {
      position: fixed;
      left: 0;
      right: 0;
      bottom: 0;
      z-index: 90;
      padding: 1rem;
      background: var(--color-bg-elev);
      border-top: 1px solid var(--color-border);
    }
    .cc__inner {
      max-width: 72rem;
      margin: 0 auto;
      display: flex;
      flex-direction: column;
      gap: 0.85rem;
    }
    @media (min-width: 640px) {
      .cc__inner { flex-direction: row; align-items: center; justify-content: space-between; }
    }
    .cc__text {
      font-size: 0.8rem;
      line-height: 1.5;
      color: var(--color-fg-muted);
    }
    .cc__text a { color: var(--color-primary-300); text-decoration: underline; }
    .cc__actions { display: flex; gap: 0.6rem; flex-shrink: 0; }
    .cc__btn {
      padding: 0.55rem 1.1rem;
      border-radius: 0.5rem;
      font-size: 0.85rem;
      font-weight: 600;
      cursor: pointer;
      border: 1px solid transparent;
      white-space: nowrap;
    }
    .cc__btn--yes { background: var(--color-primary-500); color: var(--color-on-primary); }
    .cc__btn--yes:hover { background: var(--color-primary-600); }
    .cc__btn--ghost { background: transparent; border-color: var(--color-border); color: var(--color-fg-muted); }
    .cc__btn--ghost:hover { color: var(--color-fg); }
  </style>

  <script is:inline define:vars={{ gaId, gtmId }}>
    (function () {
      var KEY = 'xlugar_cookie_consent';

      function loadAnalytics() {
        if (window.__xlugarAnalytics) return;
        window.__xlugarAnalytics = true;
        window.dataLayer = window.dataLayer || [];

        if (gtmId) {
          (function (w, d, s, l, i) {
            w[l] = w[l] || [];
            w[l].push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' });
            var f = d.getElementsByTagName(s)[0],
              j = d.createElement(s),
              dl = l != 'dataLayer' ? '&l=' + l : '';
            j.async = true;
            j.src = 'https://www.googletagmanager.com/gtm.js?id=' + i + dl;
            f.parentNode.insertBefore(j, f);
          })(window, document, 'script', 'dataLayer', gtmId);
        }

        if (gaId) {
          var g = document.createElement('script');
          g.async = true;
          g.src = 'https://www.googletagmanager.com/gtag/js?id=' + gaId;
          document.head.appendChild(g);
          function gtag() { dataLayer.push(arguments); }
          window.gtag = gtag;
          gtag('js', new Date());
          gtag('config', gaId);
        }
      }

      function decide(value) {
        try { localStorage.setItem(KEY, value); } catch (e) {}
        var banner = document.getElementById('cookie-consent');
        if (banner) banner.hidden = true;
        if (value === 'granted') loadAnalytics();
      }

      function init() {
        var choice = null;
        try { choice = localStorage.getItem(KEY); } catch (e) {}

        if (choice === 'granted') { loadAnalytics(); return; }
        if (choice === 'denied') { return; }

        // No choice yet → show the banner and wire the buttons.
        var banner = document.getElementById('cookie-consent');
        if (!banner) return;
        banner.hidden = false;
        var accept = document.getElementById('cc-accept');
        var reject = document.getElementById('cc-reject');
        if (accept) accept.addEventListener('click', function () { decide('granted'); });
        if (reject) reject.addEventListener('click', function () { decide('denied'); });
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
      } else {
        init();
      }
      document.addEventListener('astro:page-load', init);
    })();
  </script>
)}
