---
import { SITE } from '@lib/site';
const year = 2026;
const nav = [
  { href: '/models', label: 'Models' },
  { href: '/categories', label: 'Categories' },
  { href: '/blog', label: 'Blog' },
  { href: '/about', label: 'About' },
];
const legal = [
  { href: '/privacy', label: 'Privacy' },
  { href: '/terms', label: 'Terms' },
  { href: '/2257', label: '2257' },
  { href: '/dmca', label: 'DMCA' },
];
---
<footer class="border-t border-border bg-bg-elev">
  <div class="mx-auto flex max-w-6xl flex-col gap-6 px-5 py-12 sm:flex-row sm:items-start sm:justify-between sm:px-8">
    <div>
      <p class="font-display text-lg text-fg">x<span class="text-primary-500">Lugar</span></p>
      <p class="mt-1 text-sm text-fg-subtle">Live cam models, streaming now · 18+ only</p>
    </div>
    <div class="flex flex-col gap-3">
      <nav aria-label="Footer">
        <ul class="flex flex-wrap gap-x-6 gap-y-2 text-sm text-fg-muted">
          {nav.map((l) => (
            <li><a href={l.href} class="hover:text-premium-300">{l.label}</a></li>
          ))}
        </ul>
      </nav>
      <nav aria-label="Legal">
        <ul class="flex flex-wrap gap-x-6 gap-y-2 text-xs text-fg-subtle">
          {legal.map((l) => (
            <li><a href={l.href} class="hover:text-premium-300">{l.label}</a></li>
          ))}
        </ul>
      </nav>
    </div>
  </div>
  <div class="border-t border-border">
    <div class="mx-auto max-w-6xl px-5 py-4 sm:px-8">
      <p class="text-xs text-fg-subtle">
        © {year} {SITE.name}. All rights reserved. This site contains adult content and is intended for adults
        18 years or older (21 where required). All models are verified adults. {SITE.name} participates in the
        Chaturbate affiliate program and may earn a commission from links on this site.
      </p>
    </div>
  </div>
</footer>
