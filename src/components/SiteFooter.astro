---
import { SITE } from '@lib/site';
const year = 2026;
---
<footer class="border-t border-border bg-bg-elev">
  <div class="mx-auto flex max-w-6xl flex-col gap-6 px-5 py-12 sm:flex-row sm:items-center sm:justify-between sm:px-8">
    <div>
      <p class="font-display text-lg text-fg">x<span class="text-primary-500">Lugar</span></p>
      <p class="mt-1 text-sm text-fg-subtle">Experiencia premium · solo +18</p>
    </div>
    <nav aria-label="Pie de página">
      <ul class="flex flex-wrap gap-x-6 gap-y-2 text-sm text-fg-muted">
        <li><a href="/#catalogo" class="hover:text-premium-300">Catálogo</a></li>
        <li><a href="/legal/privacidad" class="hover:text-premium-300">Privacidad</a></li>
        <li><a href="/legal/terminos" class="hover:text-premium-300">Términos</a></li>
      </ul>
    </nav>
  </div>
  <div class="border-t border-border">
    <p class="mx-auto max-w-6xl px-5 py-4 text-xs text-fg-subtle sm:px-8">
      © {year} {SITE.name}. Todos los derechos reservados.
    </p>
  </div>
</footer>
