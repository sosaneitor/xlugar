---
import { Image } from 'astro:assets';
import Badge from '@components/ui/Badge.astro';
import type { Model } from '@data/model.schema';

interface Props {
  model: Model;
  /** Eager-load above-the-fold cards to protect LCP; lazy for the rest. */
  priority?: boolean;
}
const { model, priority = false } = Astro.props;
const { cover } = model;
---
<a
  href={`/modelos/${model.slug}`}
  class="group relative block overflow-hidden rounded-(--radius-lg) bg-surface border border-border
         transition-[transform,box-shadow] duration-(--dur-mid) ease-(--ease-out-soft)
         hover:-translate-y-1 hover:shadow-[var(--shadow-card)] focus-visible:-translate-y-1
         motion-reduce:transform-none"
  data-reveal
>
  <div class="relative aspect-[3/4] overflow-hidden">
    <Image
      src={cover.src}
      alt={cover.alt}
      width={cover.width}
      height={cover.height}
      widths={[300, 480, 640]}
      sizes="(min-width: 1024px) 25vw, (min-width: 640px) 33vw, 50vw"
      loading={priority ? 'eager' : 'lazy'}
      fetchpriority={priority ? 'high' : 'auto'}
      decoding="async"
      format="avif"
      class="h-full w-full object-cover transition-transform duration-(--dur-slow) ease-(--ease-out-soft)
             group-hover:scale-[1.05] motion-reduce:transform-none"
    />
    {/* solid gradient veil for legibility — opaque color stops, no blur/glass */}
    <div class="pointer-events-none absolute inset-x-0 bottom-0 h-2/3 bg-gradient-to-t from-bg to-transparent"></div>

    <div class="absolute left-3 top-3 flex gap-2">
      {model.premium && <Badge variant="premium" size="sm">VIP</Badge>}
      {model.rarity === 'legendary' && <Badge variant="primary" size="sm">Legendaria</Badge>}
    </div>
  </div>

  <div class="absolute inset-x-0 bottom-0 p-4">
    <h3 class="text-xl text-fg">
      {model.name}<span class="text-fg-muted font-sans font-normal text-base">, {model.age}</span>
    </h3>
    <p class="mt-0.5 text-sm text-fg-muted">{model.city} · {model.tagline}</p>
  </div>
</a>
