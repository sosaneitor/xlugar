---
import Section from '@components/ui/Section.astro';
import SectionHeading from '@components/ui/SectionHeading.astro';
import VerticalFeed from './components/VerticalFeed.tsx';
import type { Model } from '@data/model.schema';

interface Props { models: Model[] }
const { models } = Astro.props;
---
<Section id="feed" labelledby="feed-title" class="bg-bg-elev">
  <div class="grid items-center gap-10 lg:grid-cols-2 lg:gap-16">
    <div class="order-2 lg:order-1" data-reveal style="--reveal-delay: 80ms">
      {/* Interactive island: snap feed with autoplay/pause */}
      <VerticalFeed models={models} client:visible />
    </div>

    <div class="order-1 lg:order-2">
      <SectionHeading
        eyebrow="Feed"
        eyebrowVariant="crimson"
        title="Un feed que fluye"
        id="feed-title"
      >
        <p class="text-fg-muted">
          Desplázate en vertical con snap suave. El vídeo se reproduce solo al entrar
          en pantalla y se pausa al salir — sin malgastar batería ni datos.
        </p>
      </SectionHeading>
    </div>
  </div>
</Section>
