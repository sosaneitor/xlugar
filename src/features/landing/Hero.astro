---
import Button from '@components/ui/Button.astro';
import Badge from '@components/ui/Badge.astro';
import LiveCount from '@features/catalog/components/LiveCount.tsx';
import HeroModelArt from './HeroModelArt.astro';
import { buildRetentionLink } from '@features/affiliate/utils/whiteLabel';

// Hero visual, all optional via env so no missing-file 404s until an asset is
// provided. Drop a LICENSED image/video (CB affiliate promo tool, AI render, or
// stock) and point these at it; otherwise the compliant SVG silhouette shows.
const heroImage = import.meta.env.PUBLIC_HERO_IMAGE?.trim();
const heroVideoWebm = import.meta.env.PUBLIC_HERO_VIDEO_WEBM?.trim();
const heroVideoMp4 = import.meta.env.PUBLIC_HERO_VIDEO_MP4?.trim();
const heroPoster = import.meta.env.PUBLIC_HERO_POSTER?.trim() || heroImage;
const hasHeroVideo = Boolean(heroVideoWebm || heroVideoMp4);
---
<section class="relative isolate overflow-hidden" aria-labelledby="hero-title">
  {/* Decorative parallax glow layers — transform-only, behind content */}
  <div class="pointer-events-none absolute inset-0 -z-10" aria-hidden="true">
    <div
      data-parallax="0.18"
      class="absolute -left-24 -top-24 h-96 w-96 rounded-full bg-primary-700 opacity-30 blur-[120px]"
    ></div>
    <div
      data-parallax="0.1"
      class="absolute -right-24 top-40 h-[28rem] w-[28rem] rounded-full bg-accent-500 opacity-25 blur-[140px]"
    ></div>
  </div>

  <div class="mx-auto grid max-w-6xl items-center gap-10 px-5 pb-20 pt-20 sm:px-8 sm:pt-28 lg:grid-cols-2 lg:gap-12 lg:pb-28">
    {/* Text column */}
    <div class="flex flex-col items-center text-center lg:items-start lg:text-left">
      <div data-reveal>
        <Badge variant="premium" size="md">Live cams · 18+</Badge>
      </div>

      <h1
        id="hero-title"
        class="mt-6 max-w-3xl text-balance text-5xl leading-[1.04] text-fg sm:text-6xl md:text-7xl"
        data-reveal
        style="--reveal-delay: 60ms"
        transition:name="hero-title"
      >
        Thousands of models,
        <span class="bg-clip-text text-transparent [background-image:var(--gradient-brand)]">
          live right now.
        </span>
      </h1>

      <p
        class="mt-6 max-w-xl text-lg text-fg-muted"
        data-reveal
        style="--reveal-delay: 120ms"
      >
        A real-time catalog of live cam models, ranked by who's drawing the biggest crowd this minute and
        refreshed continuously. Free to watch — find your room in seconds.
      </p>

      <div data-reveal style="--reveal-delay: 150ms">
        <LiveCount client:visible />
      </div>

      <div class="mt-9 flex flex-wrap items-center justify-center gap-4 lg:justify-start" data-reveal style="--reveal-delay: 180ms">
        <Button
          href={buildRetentionLink('home')}
          variant="gradient"
          size="lg"
          rel="sponsored noopener noreferrer"
          target="_blank"
        >
          Enter live cams
        </Button>
        <Button href="/models" variant="ghost" size="lg">Browse the catalog</Button>
      </div>
    </div>

    {/* Model column — looping 3D render. Video on top on mobile, right on desktop.
        The wrapper reserves space (aspect ratio -> no CLS) and its brand gradient
        doubles as the placeholder until the video/poster assets are in place. */}
    <div class="order-first lg:order-last" data-reveal style="--reveal-delay: 100ms">
      <div
        class="relative mx-auto aspect-[3/4] w-full max-w-sm max-h-[55vh] overflow-hidden rounded-(--radius-lg)
               border border-border [background-image:var(--gradient-brand)] lg:max-h-none"
      >
        {/* Base layer: compliant SVG silhouette (shows until a real asset is set) */}
        <HeroModelArt />

        {/* Real asset (licensed) — video preferred, else image. Env-gated. */}
        {hasHeroVideo ? (
          <video
            data-hero-video
            poster={heroPoster}
            muted
            loop
            playsinline
            preload="none"
            class="relative z-[2] h-full w-full object-cover"
            aria-hidden="true"
          >
            {heroVideoWebm && <source src={heroVideoWebm} type="video/webm" />}
            {heroVideoMp4 && <source src={heroVideoMp4} type="video/mp4" />}
          </video>
        ) : heroImage ? (
          <img
            src={heroImage}
            alt=""
            class="relative z-[2] h-full w-full object-cover"
            loading="eager"
            decoding="async"
          />
        ) : null}

        {/* Soft inner vignette for legibility/depth over the render */}
        <div class="pointer-events-none absolute inset-0 z-10 bg-gradient-to-t from-bg/70 via-transparent to-transparent"></div>
      </div>
    </div>
  </div>

  {/* Scroll cue — invites the user down into the live catalog (#live). */}
  <a
    href="#live"
    aria-label="Scroll to live models"
    class="scroll-cue absolute bottom-5 left-1/2 z-10 -translate-x-1/2 text-fg-subtle transition-colors hover:text-premium-300"
  >
    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M6 9l6 6 6-6" />
    </svg>
  </a>
</section>
