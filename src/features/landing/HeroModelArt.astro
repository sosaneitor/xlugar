---
/**
 * Compliant hero placeholder: a stylized, non-explicit female silhouette drawn
 * in SVG (no real person, no likeness/copyright/2257 concerns). Sits as the base
 * layer of the hero visual; a real licensed poster/video (when added) renders on
 * top and covers it. Purely decorative.
 */
---
<div class="pointer-events-none absolute inset-0 flex items-end justify-center" aria-hidden="true">
  <svg
    viewBox="0 0 240 400"
    class="hero-figure h-[92%] w-auto"
    preserveAspectRatio="xMidYMax meet"
    role="presentation"
  >
    <defs>
      <linearGradient id="heroFigureFill" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="var(--c-bg)" stop-opacity="0.30" />
        <stop offset="55%" stop-color="var(--c-bg)" stop-opacity="0.62" />
        <stop offset="100%" stop-color="var(--c-bg)" stop-opacity="0.9" />
      </linearGradient>
    </defs>
    <g fill="url(#heroFigureFill)">
      {/* Hair / head backdrop */}
      <path d="M120 22c-28 0-44 20-44 48 0 16 7 28 18 35-6 4-10 10-10 18 0 0 12 8 36 8s36-8 36-8c0-8-4-14-10-18 11-7 18-19 18-35 0-28-16-48-44-48Z" />
      {/* Torso — hourglass figure cropped at the frame bottom */}
      <path d="M120 104c30 3 46 18 53 49 6 30-22 55-24 99-1 40 17 60 20 90l4 58H67l4-58c3-30 21-50 20-90-2-44-30-69-24-99 7-31 23-46 53-49Z" />
    </g>
  </svg>
</div>
<style>
  /* Gentle float; disabled under reduced motion via the global rule. */
  .hero-figure {
    animation: float-y 6s var(--ease-out-soft) infinite;
    will-change: transform;
  }
</style>
