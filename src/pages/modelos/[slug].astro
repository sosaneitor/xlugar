---
import { Image } from 'astro:assets';
import BaseLayout from '@layouts/BaseLayout.astro';
import SiteHeader from '@components/SiteHeader.astro';
import SiteFooter from '@components/SiteFooter.astro';
import Section from '@components/ui/Section.astro';
import Badge from '@components/ui/Badge.astro';
import Button from '@components/ui/Button.astro';
import { getModels } from '@data/getModels';
import { profileSchema, breadcrumbSchema } from '@lib/schema';

export async function getStaticPaths() {
  const models = await getModels();
  return models.map((model) => ({
    params: { slug: model.slug },
    props: { model },
  }));
}

const { model } = Astro.props;

const schemas = [
  profileSchema({
    name: model.name,
    slug: model.slug,
    description: model.bio,
    image: model.cover.src,
    city: model.city,
  }),
  breadcrumbSchema([
    { name: 'Inicio', path: '/' },
    { name: 'Modelos', path: '/#catalogo' },
    { name: model.name, path: `/modelos/${model.slug}` },
  ]),
];
---
<BaseLayout
  title={`${model.name}, ${model.age} · ${model.city}`}
  description={model.bio}
  image={model.cover.src}
  type="profile"
  schemas={schemas}
>
  <SiteHeader slot="header" />

  <article>
    <Section as="header" class="pt-12 sm:pt-16" labelledby="profile-title">
      <nav aria-label="Ruta de navegación" class="mb-8 text-sm text-fg-subtle">
        <a href="/" class="hover:text-premium-300">Inicio</a>
        <span class="px-2">/</span>
        <a href="/#catalogo" class="hover:text-premium-300">Modelos</a>
        <span class="px-2">/</span>
        <span class="text-fg-muted">{model.name}</span>
      </nav>

      <div class="grid gap-10 lg:grid-cols-[minmax(0,420px)_1fr] lg:gap-14">
        <div class="overflow-hidden rounded-(--radius-xl) border border-border" transition:name={`cover-${model.slug}`}>
          <Image
            src={model.cover.src}
            alt={model.cover.alt}
            width={model.cover.width}
            height={model.cover.height}
            widths={[420, 640, 840]}
            sizes="(min-width: 1024px) 420px, 90vw"
            loading="eager"
            fetchpriority="high"
            format="avif"
            class="aspect-[3/4] h-full w-full object-cover"
          />
        </div>

        <div class="flex flex-col justify-center" data-reveal>
          <div class="mb-4 flex flex-wrap gap-2">
            {model.premium && <Badge variant="premium">VIP</Badge>}
            <Badge variant="outline">{model.city}</Badge>
            {model.tags.map((t) => <Badge variant="neutral" size="sm">{t}</Badge>)}
          </div>

          <h1 id="profile-title" class="text-4xl text-fg sm:text-5xl" transition:name={`title-${model.slug}`}>
            {model.name}<span class="font-sans text-2xl font-normal text-fg-muted">, {model.age}</span>
          </h1>
          <p class="mt-3 font-display text-xl text-premium-400">{model.tagline}</p>
          <p class="mt-5 max-w-prose text-fg-muted">{model.bio}</p>

          <div class="mt-8 flex flex-wrap gap-4">
            <Button variant="primary" size="lg">Contactar</Button>
            <Button href="/#catalogo" variant="ghost" size="lg">Volver al catálogo</Button>
          </div>
        </div>
      </div>
    </Section>

    <Section labelledby="galeria-title" class="pt-0">
      <h2 id="galeria-title" class="sr-only">Galería de {model.name}</h2>
      <ul class="grid grid-cols-2 gap-4 sm:grid-cols-3" data-reveal-group data-reveal-step="80">
        {model.gallery.map((media) => (
          <li class="overflow-hidden rounded-(--radius-lg) border border-border" data-reveal>
            <Image
              src={media.src}
              alt={media.alt}
              width={media.width}
              height={media.height}
              widths={[300, 480, 640]}
              sizes="(min-width: 640px) 33vw, 50vw"
              loading="lazy"
              decoding="async"
              format="avif"
              class="aspect-[3/4] h-full w-full object-cover transition-transform duration-(--dur-slow) hover:scale-105 motion-reduce:transform-none"
            />
          </li>
        ))}
      </ul>
    </Section>
  </article>

  <SiteFooter slot="footer" />
</BaseLayout>
