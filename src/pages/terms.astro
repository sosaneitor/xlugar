---
import BaseLayout from '@layouts/BaseLayout.astro';
import SiteHeader from '@components/SiteHeader.astro';
import SiteFooter from '@components/SiteFooter.astro';
import Section from '@components/ui/Section.astro';
import { SITE } from '@lib/site';

const updated = 'June 30, 2026';
---
<BaseLayout
  title="Terms of Use"
  description="The terms that govern your use of xLugar, our 18+ policy, and affiliate disclosure."
  canonical="/terms"
>
  <SiteHeader slot="header" />

  <Section labelledby="terms-title">
    <article class="mx-auto max-w-2xl">
      <nav aria-label="Breadcrumb" class="text-sm text-fg-subtle" data-reveal>
        <a href="/" class="hover:text-premium-300">Home</a> <span aria-hidden="true">/</span>
        <span class="text-fg-muted">Terms</span>
      </nav>
      <h1 class="mt-4 text-4xl text-fg sm:text-5xl" data-reveal>Terms of Use</h1>
      <p class="mt-2 text-sm text-fg-subtle" data-reveal>Last updated: {updated}</p>

      <div class="mt-8 flex flex-col gap-5 text-fg-muted" data-reveal style="--reveal-delay: 80ms">
        <p>
          By accessing {SITE.name} you agree to these terms. If you do not agree, please do not use the site.
        </p>

        <h2 class="mt-6 text-2xl text-fg">Eligibility — 18+</h2>
        <p>
          {SITE.name} contains adult content and is strictly for adults aged 18 or older (21 where required by
          local law). By using the site you confirm you are of legal age in your jurisdiction and that adult
          content is legal where you live.
        </p>

        <h2 class="mt-6 text-2xl text-fg">What {SITE.name} provides</h2>
        <p>
          {SITE.name} is a discovery site. We surface publicly-broadcasting live cam rooms and rank them by
          current audience. We do not host, produce, record or store any streams or video. When you open a room
          you are taken to the live stream operated by Chaturbate (or a co-branded Chaturbate property), which is
          responsible for that content.
        </p>

        <h2 class="mt-6 text-2xl text-fg">Affiliate disclosure</h2>
        <p>
          {SITE.name} participates in the Chaturbate affiliate program and may earn a commission when you visit a
          room or register through links on this site, at no extra cost to you. This never affects which rooms
          appear or how they are ranked — ordering is driven purely by live viewer counts.
        </p>

        <h2 class="mt-6 text-2xl text-fg">Acceptable use</h2>
        <p>
          Do not use the site for any unlawful purpose, do not attempt to disrupt or scrape it at scale, and do
          not misrepresent your age. We may restrict access for misuse.
        </p>

        <h2 class="mt-6 text-2xl text-fg">Disclaimer and liability</h2>
        <p>
          The site is provided "as is" without warranties of any kind. Live listings change constantly and may be
          inaccurate or unavailable at any time. To the fullest extent permitted by law, {SITE.name} is not
          liable for any damages arising from your use of the site or of third-party destinations.
        </p>

        <h2 class="mt-6 text-2xl text-fg">Changes</h2>
        <p>
          We may update these terms from time to time. Continued use after changes means you accept the revised
          terms. Questions? Email <a href="mailto:legal@xlugar.com" class="text-primary-300 underline hover:text-premium-300">legal@xlugar.com</a>.
        </p>
      </div>
    </article>
  </Section>

  <SiteFooter slot="footer" />
</BaseLayout>
