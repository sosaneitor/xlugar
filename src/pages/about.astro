---
import BaseLayout from '@layouts/BaseLayout.astro';
import SiteHeader from '@components/SiteHeader.astro';
import SiteFooter from '@components/SiteFooter.astro';
import Section from '@components/ui/Section.astro';
import { SITE } from '@lib/site';
---
<BaseLayout
  title="About xLugar"
  description="xLugar is a live cam site: thousands of models streaming right now, ranked by live audience and refreshed every minute. Free to watch. 18+ only."
  canonical="/about"
>
  <SiteHeader slot="header" />

  <Section labelledby="about-title">
    <article class="mx-auto max-w-2xl">
      <h1 class="text-4xl text-fg sm:text-5xl" data-reveal>About {SITE.name}</h1>

      <div class="mt-8 flex flex-col gap-5 text-fg-muted" data-reveal style="--reveal-delay: 80ms">
        <p>
          {SITE.name} is a live cam site built around one idea: help you find a great room fast. Thousands of
          models are broadcasting at any moment, and we put the ones with the biggest live audiences in front of
          you first — sorted, filtered and refreshed every minute so you're always looking at who is actually
          online right now.
        </p>
        <p>
          Browsing and watching are free. Open any room and you go straight to the live stream, where you can
          watch, chat, tip and follow your favorites. You only need a free account if you want to join in — no
          sign-up is required just to look around.
        </p>

        <h2 class="mt-6 text-2xl text-fg">Always live, never stale</h2>
        <p>
          Every list on {SITE.name} — the home grid, the full catalog and each category — is ranked by current
          viewers and reordered continuously as audiences shift. The previews are snapshots that refresh about
          once a minute so the page stays fast; the real action is always inside the room. Models come and go all
          day, so the lineup is never the same twice.
        </p>

        <h2 class="mt-6 text-2xl text-fg">Adults only — 18+</h2>
        <p>
          {SITE.name} contains adult content and is strictly for adults aged 18 or older (21 where required by
          local law). All performers are verified adults. If you are a minor, or if adult content is illegal
          where you live, please leave now. See our <a href="/terms" class="text-primary-300 underline hover:text-premium-300">Terms</a>,
          <a href="/privacy" class="text-primary-300 underline hover:text-premium-300">Privacy Policy</a> and
          <a href="/2257" class="text-primary-300 underline hover:text-premium-300">18 U.S.C. 2257 statement</a>.
        </p>

        <p class="text-sm text-fg-subtle">
          {SITE.name} participates in the Chaturbate affiliate program and may earn a commission from links on
          this site, at no extra cost to you. This never affects how rooms are ranked — ordering is driven purely
          by live viewer counts.
        </p>
      </div>
    </article>
  </Section>

  <SiteFooter slot="footer" />
</BaseLayout>
