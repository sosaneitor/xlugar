---
import BaseLayout from '@layouts/BaseLayout.astro';
import SiteHeader from '@components/SiteHeader.astro';
import SiteFooter from '@components/SiteFooter.astro';
import Section from '@components/ui/Section.astro';
import { breadcrumbSchema } from '@lib/schema';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);

const breadcrumbs = breadcrumbSchema([
  { name: 'Home', path: '/' },
  { name: 'Blog', path: '/blog' },
]);

const dateFmt = new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---
<BaseLayout
  title="Blog — Guides & News"
  description="Guides, tips and news about live cam shows, performers and getting the most out of the experience. From the xLugar team."
  canonical="/blog"
  schemas={[breadcrumbs]}
>
  <SiteHeader slot="header" />

  <Section labelledby="blog-title">
    <header class="flex max-w-2xl flex-col gap-4" data-reveal>
      <h1 class="text-4xl text-fg sm:text-5xl">The xLugar blog</h1>
      <p class="text-fg-muted">Guides, tips and news to help you get more out of live cam shows.</p>
    </header>

    {posts.length === 0 ? (
      <p class="mt-10 text-fg-muted">No posts yet — check back soon.</p>
    ) : (
      <ul class="mt-10 grid gap-6 sm:grid-cols-2" data-reveal-group data-reveal-step="70">
        {posts.map((post) => (
          <li>
            <a
              href={`/blog/${post.slug}`}
              class="flex h-full flex-col gap-3 rounded-(--radius-lg) border border-border bg-surface p-6
                     transition-[transform,border-color] duration-(--dur-mid) ease-(--ease-out-soft)
                     hover:-translate-y-1 hover:border-premium-500 motion-reduce:transform-none"
            >
              <time datetime={post.data.pubDate.toISOString()} class="text-xs uppercase tracking-[0.12em] text-fg-subtle">
                {dateFmt.format(post.data.pubDate)}
              </time>
              <h2 class="text-2xl text-fg">{post.data.title}</h2>
              <p class="text-sm text-fg-muted">{post.data.description}</p>
              <span class="mt-auto text-sm text-premium-300">Read more →</span>
            </a>
          </li>
        ))}
      </ul>
    )}
  </Section>

  <SiteFooter slot="footer" />
</BaseLayout>
