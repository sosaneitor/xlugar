---
import BaseLayout from './BaseLayout.astro';
import SiteHeader from '@components/SiteHeader.astro';
import SiteFooter from '@components/SiteFooter.astro';
import Section from '@components/ui/Section.astro';
import AdSlot from '@features/ads/components/AdSlot.astro';
import { articleSchema, breadcrumbSchema } from '@lib/schema';
import { CATEGORIES, FEATURED_CATEGORIES, getCategoryBySlug } from '@features/catalog/data/categories';
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'blog'>;
}
const { entry } = Astro.props;
const { data } = entry;
const path = `/blog/${entry.slug}`;

// Contextual internal links: use the post's declared related categories, else
// fall back to the featured set so every article links out to category pages.
const relatedCats = (data.relatedCategories ?? [])
  .map((slug) => getCategoryBySlug(slug))
  .filter((c): c is (typeof CATEGORIES)[number] => Boolean(c));
const linkedCategories = relatedCats.length > 0 ? relatedCats : FEATURED_CATEGORIES;

const schemas = [
  breadcrumbSchema([
    { name: 'Home', path: '/' },
    { name: 'Blog', path: '/blog' },
    { name: data.title, path },
  ]),
  articleSchema({
    title: data.title,
    description: data.description,
    path,
    datePublished: data.pubDate.toISOString(),
    dateModified: data.updatedDate?.toISOString(),
    image: data.heroImage,
  }),
];

const dateFmt = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---
<BaseLayout
  title={data.title}
  description={data.description}
  canonical={path}
  image={data.heroImage}
  type="article"
  schemas={schemas}
>
  <SiteHeader slot="header" />

  <Section labelledby="post-title">
    <div class="mx-auto max-w-3xl">
      <AdSlot variant="banner" slotId="blog-top" class="mb-10" />

      <nav aria-label="Breadcrumb" class="text-sm text-fg-subtle">
        <a href="/" class="hover:text-premium-300">Home</a> <span aria-hidden="true">/</span>
        <a href="/blog" class="hover:text-premium-300">Blog</a> <span aria-hidden="true">/</span>
        <span class="text-fg-muted">{data.title}</span>
      </nav>

      <header class="mt-4 flex flex-col gap-3">
        <h1 class="text-4xl text-fg sm:text-5xl">{data.title}</h1>
        <p class="text-fg-muted">{data.description}</p>
        <time datetime={data.pubDate.toISOString()} class="text-sm text-fg-subtle">
          {dateFmt.format(data.pubDate)}
        </time>
      </header>

      <div class="post-body mt-10 flex flex-col gap-5 text-fg-muted">
        <slot />
      </div>

      {/* Contextual internal links to live category pages + catalog CTA. */}
      <nav class="mt-14 border-t border-border pt-8" aria-label="Related categories">
        <h2 class="text-sm uppercase tracking-[0.14em] text-fg-subtle">Explore live categories</h2>
        <ul class="mt-4 flex flex-wrap gap-3">
          {linkedCategories.map((c) => (
            <li>
              <a
                href={`/models/${c.slug}`}
                class="rounded-(--radius-pill) border border-border-strong bg-surface px-4 py-2 text-sm text-fg-muted
                       transition-colors duration-(--dur-fast) hover:border-premium-500 hover:text-premium-300"
              >
                {c.label} cams
              </a>
            </li>
          ))}
        </ul>
        <p class="mt-6">
          <a href="/models" class="text-premium-300 hover:text-premium-400">Browse the full live catalog →</a>
        </p>
      </nav>
    </div>
  </Section>

  <SiteFooter slot="footer" />
</BaseLayout>

<style is:global>
  /* Article prose rhythm using design tokens only. */
  .post-body h2 { color: var(--c-fg); font-size: 1.75rem; margin-top: 1.5rem; }
  .post-body h3 { color: var(--c-fg); font-size: 1.35rem; margin-top: 1rem; }
  .post-body a { color: var(--c-primary-300); text-decoration: underline; }
  .post-body a:hover { color: var(--c-premium-300); }
  .post-body ul { padding-left: 1.25rem; list-style: disc; }
  .post-body li { margin-top: 0.35rem; }
  .post-body strong { color: var(--c-fg); }
</style>
