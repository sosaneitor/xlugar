---
import { ClientRouter } from 'astro:transitions';
import { SITE } from '@lib/site';
import { websiteSchema } from '@lib/schema';
import Seo from '@components/seo/Seo.astro';
import JsonLd from '@components/seo/JsonLd.astro';
import Motion from '@components/Motion.astro';
import AgeGate from '@components/AgeGate.astro';
import CookieConsent from '@components/CookieConsent.astro';
import '@styles/global.css';

// Analytics / tag manager IDs — both optional; markup is a no-op when unset.
// These are handed to CookieConsent, which loads them ONLY after consent.
const GA_ID = import.meta.env.PUBLIC_GA_MEASUREMENT_ID?.trim();
const GTM_ID = import.meta.env.PUBLIC_GTM_ID?.trim();

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  image?: string;
  type?: 'website' | 'profile' | 'article';
  rawTitle?: boolean;
  noindex?: boolean;
  /** Explicit robots directive (e.g. "noindex, follow"); overrides `noindex`. */
  robots?: string;
  /** Extra JSON-LD graphs for this page (breadcrumbs, profile, etc.). */
  schemas?: (Record<string, unknown> | Record<string, unknown>[])[];
}

const {
  title,
  description,
  canonical,
  image,
  type,
  rawTitle,
  noindex,
  robots,
  schemas = [],
} = Astro.props;
---
<!doctype html>
<html lang={SITE.lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#17090f" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    {/* Age gate: mark <html> as confirmed BEFORE paint so there is no flash of
        the gate (repeat visitors) nor of the content (first-time visitors). */}
    <script is:inline>
      try {
        if (localStorage.getItem('xlugar_age_ok')) {
          document.documentElement.classList.add('age-ok');
        }
      } catch (e) {}
    </script>

    {/* LCP-critical display font preloaded; both are self-hosted with font-display: swap. */}
    <link
      rel="preload"
      href="/fonts/syne-var.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <Seo
      title={title}
      description={description}
      canonical={canonical}
      image={image}
      type={type}
      rawTitle={rawTitle}
      noindex={noindex}
      robots={robots}
    />

    {/* Site-wide structured data */}
    <JsonLd schema={websiteSchema()} />
    {schemas.map((s) => <JsonLd schema={s} />)}

    {/* Analytics (GA4 / GTM) is loaded by <CookieConsent> only after consent. */}

    {/* Smooth client-side navigation + shared-element transitions */}
    <ClientRouter />
  </head>
  <body>
    <a href="#main" class="sr-only focus:not-sr-only">Skip to content</a>
    <slot name="header" />
    <main id="main">
      <slot />
    </main>
    <slot name="footer" />
    <AgeGate />
    <CookieConsent gaId={GA_ID} gtmId={GTM_ID} />
    <Motion />
  </body>
</html>
