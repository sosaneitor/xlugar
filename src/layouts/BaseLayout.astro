---
import { ClientRouter } from 'astro:transitions';
import { SITE } from '@lib/site';
import { websiteSchema } from '@lib/schema';
import Seo from '@components/seo/Seo.astro';
import JsonLd from '@components/seo/JsonLd.astro';
import Motion from '@components/Motion.astro';
import '@styles/global.css';

// Analytics / tag manager IDs — both optional; markup is a no-op when unset.
const GA_ID = import.meta.env.PUBLIC_GA_MEASUREMENT_ID?.trim();
const GTM_ID = import.meta.env.PUBLIC_GTM_ID?.trim();

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  image?: string;
  type?: 'website' | 'profile' | 'article';
  rawTitle?: boolean;
  noindex?: boolean;
  /** Extra JSON-LD graphs for this page (breadcrumbs, profile, etc.). */
  schemas?: (Record<string, unknown> | Record<string, unknown>[])[];
}

const {
  title,
  description,
  canonical,
  image,
  type,
  rawTitle,
  noindex,
  schemas = [],
} = Astro.props;
---
<!doctype html>
<html lang={SITE.lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#17090f" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    {/* LCP-critical display font preloaded; both are self-hosted with font-display: swap. */}
    <link
      rel="preload"
      href="/fonts/syne-var.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <Seo
      title={title}
      description={description}
      canonical={canonical}
      image={image}
      type={type}
      rawTitle={rawTitle}
      noindex={noindex}
    />

    {/* Site-wide structured data */}
    <JsonLd schema={websiteSchema()} />
    {schemas.map((s) => <JsonLd schema={s} />)}

    {/* Google Tag Manager (placeholder container — fill in GTM) */}
    {GTM_ID && (
      <script is:inline set:html={`(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);})(window,document,'script','dataLayer','${GTM_ID}');`} />
    )}

    {/* Google Analytics 4 */}
    {GA_ID && (
      <>
        <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}></script>
        <script is:inline set:html={`window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','${GA_ID}');`} />
      </>
    )}

    {/* Smooth client-side navigation + shared-element transitions */}
    <ClientRouter />
  </head>
  <body>
    {GTM_ID && (
      <noscript set:html={`<iframe src="https://www.googletagmanager.com/ns.html?id=${GTM_ID}" height="0" width="0" style="display:none;visibility:hidden"></iframe>`} />
    )}
    <a href="#main" class="sr-only focus:not-sr-only">Skip to content</a>
    <slot name="header" />
    <main id="main">
      <slot />
    </main>
    <slot name="footer" />
    <Motion />
  </body>
</html>
